#!/usr/bin/env bash
# SessionStart hook for xo1997-dev plugin

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read using-xo1997-dev content
using_skill_content=$(cat "${PLUGIN_ROOT}/skills/using-xo1997-dev/SKILL.md" 2>&1 || echo "Error reading using-xo1997-dev skill")

# Escape string for JSON embedding using bash parameter substitution.
# Each ${s//old/new} is a single C-level pass - orders of magnitude
# faster than the character-by-character loop this replaces.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

using_skill_escaped=$(escape_for_json "$using_skill_content")

# Check for stale worktrees
worktree_warning=""
if command -v git &> /dev/null && git rev-parse --git-dir &> /dev/null 2>&1; then
    # Check for .worktrees or worktrees directory
    worktree_dir=""
    if [ -d ".worktrees" ]; then
        worktree_dir=".worktrees"
    elif [ -d "worktrees" ]; then
        worktree_dir="worktrees"
    fi

    if [ -n "$worktree_dir" ]; then
        # Count worktrees (excluding current)
        current_branch=$(git branch --show-current 2>/dev/null || echo "")
        stale_worktrees=$(git worktree list --porcelain 2>/dev/null | grep -c "worktree" || echo "0")
        if [ "$stale_worktrees" -gt 1 ]; then
            worktree_warning="\n\n<WORKTREE_WARNING>\n检测到存在 $((stale_worktrees - 1)) 个残留的 worktree。如果之前的工作已结束但未清理，请运行 'git worktree list' 查看，并使用 'git worktree remove <path>' 清理。\n</WORKTREE_WARNING>"
        fi
    fi
fi

worktree_warning_escaped=$(escape_for_json "$worktree_warning")

session_context="<EXTREMELY_IMPORTANT>\nYou have xo1997-dev skills.\n\n**Below is the full content of your 'xo1997-dev:using-xo1997-dev' skill - your introduction to using skills. For all other skills, use the 'Skill' tool:**\n\n${using_skill_escaped}${worktree_warning_escaped}\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON.
# Cursor hooks expect additional_context.
# Claude Code hooks expect hookSpecificOutput.additionalContext.
# Claude Code reads BOTH fields without deduplication, so we must only
# emit the field consumed by the current platform to avoid double injection.
if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  # Claude Code sets CLAUDE_PLUGIN_ROOT — emit only hookSpecificOutput
  cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF
else
  # Other platforms (Cursor, etc.) — emit only additional_context
  cat <<EOF
{
  "additional_context": "${session_context}"
}
EOF
fi

exit 0
